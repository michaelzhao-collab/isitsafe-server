# 服务端口
PORT=3000

# 数据库（必须）
DATABASE_URL="postgresql://user:password@localhost:5432/isitsafe?schema=public"

# Redis（缓存 + 限流，必须）
REDIS_URL="redis://localhost:6379"
# 或分开配置：
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT（用户与 Admin 共用）
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# AI 提供商：doubao | deepseek | openai | other（预留）
AI_PROVIDER=doubao
# 主 provider 失败时自动切换的备用 provider；留空 = 不切换。推荐 deepseek 兜底豆包。
AI_FALLBACK_PROVIDER=deepseek

# 豆包（主，国内合规、响应快）
DOUBAO_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# DeepSeek（备，推理强、JSON 输出稳定）
# deepseek-chat = V3.x 通用；deepseek-reasoner = R1 推理模式（延迟更高）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（海外）
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 可选：统一 AI Base URL（仅影响 OpenAI；豆包/DeepSeek 用各自的 API_URL）
# AI_BASE_URL=

# 登录防刷
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Apple IAP / Sign in with Apple（必须，否则 /api/subscription/verify、apple-notification、Apple 登录全部 401）
# 值为 App Store Connect 上 iOS App 的 Bundle ID，例如 com.starlens.isitsafe
APPLE_BUNDLE_ID=
# 兼容别名（任填一个即可，三者优先级 APPLE_BUNDLE_ID > IOS_BUNDLE_ID > APP_BUNDLE_ID）
# IOS_BUNDLE_ID=
# APP_BUNDLE_ID=

# 图片存储：Cloudflare R2（S3 兼容）+ CDN
# 必须项；任一缺失则上传接口直接 400
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# CDN 域名（建议绑 Cloudflare 自有域名 + R2 Public Bucket）；末尾不要带斜杠
CDN_DOMAIN=https://cdn.isitsafe.com
