# 服务端口
PORT=3000

# 数据库（必须）
DATABASE_URL="postgresql://user:password@localhost:5432/isitsafe?schema=public"

# Redis（缓存 + 限流，必须）
REDIS_URL="redis://localhost:6379"
# 或分开配置：
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT（用户与 Admin 共用）
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# AI 提供商：doubao | deepseek | openai | other（预留）
AI_PROVIDER=doubao
# 主 provider 失败时自动切换的备用 provider；留空 = 不切换。推荐 deepseek 兜底豆包。
AI_FALLBACK_PROVIDER=deepseek

# 豆包（主，国内合规、响应快）
DOUBAO_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# DeepSeek（备，推理强、JSON 输出稳定）
# deepseek-chat = V3.x 通用；deepseek-reasoner = R1 推理模式（延迟更高）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（海外）
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 可选：统一 AI Base URL（仅影响 OpenAI；豆包/DeepSeek 用各自的 API_URL）
# AI_BASE_URL=

# 登录防刷
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Apple IAP / Sign in with Apple（必须，否则 /api/subscription/verify、apple-notification、Apple 登录全部 401）
# 值为 App Store Connect 上 iOS App 的 Bundle ID，例如 com.starlens.isitsafe
APPLE_BUNDLE_ID=
# 兼容别名（任填一个即可，三者优先级 APPLE_BUNDLE_ID > IOS_BUNDLE_ID > APP_BUNDLE_ID）
# IOS_BUNDLE_ID=
# APP_BUNDLE_ID=

# 图片存储：Cloudflare R2（S3 兼容）+ CDN
# 必须项；任一缺失则上传接口直接 400
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# CDN 域名（建议绑 Cloudflare 自有域名 + R2 Public Bucket）；末尾不要带斜杠
CDN_DOMAIN=https://cdn.isitsafe.com

# ====== V3 一期新增（缺失则相关功能 fallback 到 log stub）======

# APNs 推送（V3-E 关怀机制 + 家庭官方广播 + V3-A1 异步结果通知）
# 4 项必须齐全才会真实发送，否则 NotificationService.sendPush 返 delivered=false
# 配置步骤：
#  1) Apple Developer Console → Keys → 新建 APNs Authentication Key (.p8)，记录 KEY_ID
#  2) 同页面顶部找 TEAM_ID（10 字符）
#  3) AUTH_KEY 填 .p8 文件的 PEM 整段（含 BEGIN/END 行与换行）
#  4) BUNDLE_ID = iOS App 的 Bundle ID
#  5) ENV: production 走 api.push.apple.com / sandbox 走 api.sandbox.push.apple.com（dev/TestFlight）
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_AUTH_KEY=
APNS_BUNDLE_ID=
APNS_ENV=production

# 短信网关 — 国内：阿里云短信（V3-E 关怀机制 3 天未活跃兜底）
# 配置前需先在阿里云控制台：
#  1) 短信签名 "StarLens" 备案通过（个人/企业资质）
#  2) 模板 family_care_inactive 通过审核：
#     "您的家人 ${inactiveName} 已连续 ${days} 天未打开 App，请联系确认安全。"
#  3) RAM 用户开通 AliyunDysmsFullAccess 子权限
# 任一缺失则 sendSms(region='CN') 返 stub
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=StarLens
ALIYUN_SMS_TEMPLATE_CODE_FAMILY_CARE=

# 短信网关 — 海外：Twilio（V3-E 关怀机制海外用户）
# TWILIO_FROM_NUMBER 一期单号；S5 会扩展为按收信号码国家路由
# 印度 DLT / 巴西 ANATEL 需买当地号码，否则会被运营商拦截
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# S5-2 按收信号码国家路由 from-number
# JSON 映射，键 = ISO 3166-1 alpha-2，值 = 当地 Twilio 号码（含 +）
# 印度 DLT / 巴西 ANATEL 等强制本地号场景必填
# 例：{"IN":"+91xxxxxxxxxx","BR":"+55xxxxxxxxxx","US":"+11234567890"}
TWILIO_FROM_NUMBERS=

# Cloudflare Turnstile（admin 登录验证码；C 端登录暂不强制）
# TURNSTILE_SECRET_KEY=
# TURNSTILE_SITE_KEY=

# Cloudflare Access（admin 后台前置）
# CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD=
