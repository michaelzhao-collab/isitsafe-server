// IsItSafe 后端 - 严格按《Server 的 AI Prompt 设计》规范
// 数据库：PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------
// 1) users
// --------------------------------------------
model User {
  id                 String    @id @default(cuid())
  phone              String?   @unique
  email              String?   @unique
  username           String?   @unique @map("username") // 管理后台登录用，仅 ADMIN/SUPERADMIN 可设
  passwordHash       String?   @map("password_hash") // 管理后台密码 bcrypt，仅管理员
  country            String?
  avatar             String?
  nickname           String?
  wechatNickname     String?   @map("wechat_nickname") // 微信登录时的昵称，优先展示
  gender             String    @default("unknown")
  birthday           DateTime?
  role               UserRole  @default(USER)
  /// 管理员禁用账号开关：true 后所有 JWT 请求被 401 拒绝；老用户 default false 不受影响
  isDisabled         Boolean   @default(false) @map("is_disabled")
  disabledAt         DateTime? @map("disabled_at")
  disabledReason     String?   @map("disabled_reason")
  lastLogin          DateTime? @map("last_login")
  subscriptionStatus String    @default("free") @map("subscription_status") // free | premium
  subscriptionExpire DateTime? @map("subscription_expire")
  createdAt          DateTime  @default(now()) @map("created_at")

  // ====== V3 一期扩展字段 ======
  /// 加入的家庭组 id；NULL 表示未加入任何家庭组
  familyGroupId    String?   @map("family_group_id")
  /// 'personal' | 'family_owner' | 'family_member' — 用于业务侧快速判断；同步自 family_members 表
  userLevel        String    @default("personal") @map("user_level")
  /// 长辈模式开关（V3 J 模块）
  elderModeEnabled Boolean   @default(false) @map("elder_mode_enabled")
  /// 用户偏好语言（zh | en）
  language         String    @default("zh")
  /// ISO 3166-2 地区码（CN-11/US-CA），用于 F 模块海外可见性 + B 情报本地化
  regionCode       String?   @map("region_code")
  /// 最后活跃时间（用户真实主动打开 App），关怀机制核心依赖
  lastActiveAt     DateTime? @map("last_active_at")

  // ====== V3-S3-3 COPPA / 未成年人 ======
  /// 是否标记为未成年（注册时按 birthday 自动推算 或 自报）
  isMinor         Boolean   @default(false) @map("is_minor")
  /// 监护人同意时间戳；NULL = 未勾选；用于家庭组加入审计
  parentConsentAt DateTime? @map("parent_consent_at")

  queries        Query[]
  reports        Report[]
  subscriptions  Subscription[]
  messageReads   UserMessageRead[]
  authIdentities AuthIdentity[]
  devices        UserDevice[]

  // ====== V3 关联关系 ======
  ownedFamilyGroups    FamilyGroup[]         @relation("FamilyGroupOwner")
  familyMembers        FamilyMember[]
  familyAliasesCreated FamilyMemberAlias[]   @relation("FamilyAliasesCreated")
  userActivities       UserActivity[]
  triggeredBroadcasts  FamilyBroadcast[]
  intelSubmissions     IntelSubmission[]
  intelDeliveries      IntelDelivery[]
  intelPreferences     UserIntelPreferences?
  deepfakeChecks       DeepfakeCheck[]
  breachTargets        BreachTarget[]
  breachAlerts         BreachAlert[]

  @@index([familyGroupId])
  @@index([lastActiveAt(sort: Desc)])
  @@index([regionCode])
  @@index([isMinor])
  @@map("users")
}

// --------------------------------------------
// V3-E 家庭守护：家庭组
// --------------------------------------------
model FamilyGroup {
  id                  String    @id @default(cuid())
  ownerUserId         String    @map("owner_user_id")
  // S3-4：owner 删号 = 家庭组解散（避免孤立的无主组）
  owner               User      @relation("FamilyGroupOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name                String?   @db.VarChar(100)
  inviteCode          String?   @unique @map("invite_code") @db.VarChar(20)
  inviteCodeExpiresAt DateTime? @map("invite_code_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  members     FamilyMember[]
  careNotices FamilyCareNotice[]
  broadcasts  FamilyBroadcast[]

  @@index([ownerUserId])
  @@map("family_groups")
}

// --------------------------------------------
// V3-E 家庭守护：家庭成员
// --------------------------------------------
model FamilyMember {
  id                String      @id @default(cuid())
  groupId           String      @map("group_id")
  group             FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId            String      @map("user_id")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// owner | guardian | ward
  role              String
  /// 该成员是否允许"查询结果触发官方广播"
  shareQueryResults Boolean     @default(true) @map("share_query_results")
  /// S5-12 成员在此家庭内的自我命名（owner 也是 member，自己改自己）
  /// NULL → 回退到 user.nickname；非 NULL → 全员可见的家庭内称呼
  displayName       String?     @map("display_name") @db.VarChar(64)
  joinedAt          DateTime    @default(now()) @map("joined_at")

  /// S5-12 别人给我打的私人备注（仅其他成员可见自己设的备注）
  aliasesReceived FamilyMemberAlias[] @relation("AliasesForMember")

  @@unique([groupId, userId])
  @@index([userId])
  @@map("family_members")
}

/// S5-12 家庭内私人备注
/// 任一成员可以给同家庭其他成员起备注；仅备注的创建者本人可见
/// 不影响 APP 全局 user.nickname
model FamilyMemberAlias {
  id             String       @id @default(cuid())
  /// 被备注的目标 family_member
  familyMemberId String       @map("family_member_id")
  familyMember   FamilyMember @relation("AliasesForMember", fields: [familyMemberId], references: [id], onDelete: Cascade)
  /// 备注创建者
  creatorUserId  String       @map("creator_user_id")
  creator        User         @relation("FamilyAliasesCreated", fields: [creatorUserId], references: [id], onDelete: Cascade)
  alias          String       @db.VarChar(64)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([familyMemberId, creatorUserId])
  @@index([creatorUserId])
  @@map("family_member_aliases")
}

// --------------------------------------------
// V3-E 关怀机制：用户每日活跃日志
// 复合主键 (user_id, date)；服务端 cron 每日扫描找出连续未活跃成员
// --------------------------------------------
model UserActivity {
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime  @db.Date
  activeCount    Int       @default(0) @map("active_count")
  firstActiveAt  DateTime? @map("first_active_at")
  lastActiveAt   DateTime? @map("last_active_at")
  /// V3-S2-1 启动来源去重数组：['cold_launch','foreground',...]
  /// PRD"真实主动"判定依据；push_tap 无对应客户端触发，不会出现在数组里
  triggerSources Json      @default("[]") @map("trigger_sources")

  @@id([userId, date])
  @@index([date])
  @@map("user_activities")
}

// --------------------------------------------
// V3-E 关怀机制：提醒发送记录（防重复轰炸）
// --------------------------------------------
model FamilyCareNotice {
  id              String      @id @default(cuid())
  groupId         String      @map("group_id")
  group           FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// 谁未活跃
  inactiveUserId  String      @map("inactive_user_id")
  /// JSON 数组：通知了哪些 guardian 的 userId
  notifiedUserIds Json        @map("notified_user_ids")
  daysInactive    Int         @map("days_inactive")
  /// push | sms
  channel         String
  /// S4-4 投递状态：{ pushDelivered, pushFailed, smsDelivered, smsFailed, escalatedToSms }
  /// 关怀 cron 用它来追踪：第 2 天 push 全失败时强制升级 SMS（默认 ≥ 3 天才走 SMS）
  deliveryStatus  Json?       @map("delivery_status")
  sentAt          DateTime    @default(now()) @map("sent_at")

  @@index([groupId, sentAt(sort: Desc)])
  @@map("family_care_notices")
}

// --------------------------------------------
// V3-B 情报推送（intel）
// 系统全网官方情报 + 用户上报 + 个人偏好 + 送达日志
// --------------------------------------------
model IntelAlert {
  id               String           @id @default(cuid())
  title            String           @db.VarChar(200)
  summary          String           @db.Text
  /// TipTap JSON：套路 3 步图、配图等结构化内容
  contentBlocks    Json?            @map("content_blocks")
  /// 'impersonation' | 'phishing' | 'investment' | 'package' | ...
  category         String           @db.VarChar(64)
  /// 'normal' | 'high' | 'urgent'
  severity         String           @db.VarChar(20)
  /// JSON 数组：['CN-11', 'US-CA', '*' 全球]
  targetRegions    Json             @map("target_regions")
  /// JSON 数组：['elder', 'student', 'finance', '*' 全部]
  targetAudiences  Json             @map("target_audiences")
  language         String           @default("zh") @db.VarChar(10)
  sourceUrl        String?          @map("source_url") @db.VarChar(500)
  /// 'draft' | 'pending' | 'published' | 'archived'
  status           String           @default("draft") @db.VarChar(20)
  publishedAt      DateTime?        @map("published_at")
  /// V3-K AI 抓取来源：哪个 ContentFetchJob 抓出来的
  sourceFetchJobId String?          @map("source_fetch_job_id") @db.VarChar(64)
  sourceFetchJob   ContentFetchJob? @relation(fields: [sourceFetchJobId], references: [id], onDelete: SetNull)
  /// V3-K 封面图（从 RSS 原文 HTML 抽出来）；iOS 列表 + 详情显示
  coverImage       String?          @map("cover_image") @db.VarChar(500)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  deliveries IntelDelivery[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([language, status])
  @@index([sourceFetchJobId])
  @@map("intel_alerts")
}

/// 用户上报情报（审核后可合并到 IntelAlert）
model IntelSubmission {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String?  @db.VarChar(64)
  content         String   @db.Text
  attachments     Json? /// R2 URLs 数组
  /// 'pending' | 'approved' | 'rejected' | 'merged'
  status          String   @default("pending") @db.VarChar(20)
  mergedToIntelId String?  @map("merged_to_intel_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("intel_submissions")
}

/// 情报送达日志（用于未读数 + 防重复推送 + CTR 统计）
model IntelDelivery {
  id          String     @id @default(cuid())
  intelId     String     @map("intel_id")
  intel       IntelAlert @relation(fields: [intelId], references: [id], onDelete: Cascade)
  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt DateTime   @default(now()) @map("delivered_at")
  readAt      DateTime?  @map("read_at")

  @@unique([intelId, userId])
  @@index([userId, deliveredAt(sort: Desc)])
  @@map("intel_deliveries")
}

/// 用户情报推送偏好
model UserIntelPreferences {
  userId     String   @id @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JSON 数组：['impersonation', 'phishing', ...]
  categories Json     @default("[]")
  /// 'daily_1' | 'daily_3' | 'weekly' | 'off'
  pushFreq   String   @default("daily_1") @map("push_freq") @db.VarChar(20)
  /// 'HH:mm' 用户本地时间
  pushTime   String?  @map("push_time") @db.VarChar(5)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("user_intel_preferences")
}

// --------------------------------------------
// V3-A1 语音深伪检测
// triggered_by_user_id 用 cuid；R2 文件 24h 后自动删除（cron 维护）
// --------------------------------------------
model DeepfakeCheck {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 一期仅 'voice'；二期 'video' / 'voiceprint'
  checkType       String    @default("voice") @map("check_type") @db.VarChar(20)
  /// 'upload' | 'record' | 'share'
  sourceType      String    @map("source_type") @db.VarChar(20)
  /// R2 URL，24h 后清空（保留记录）
  fileUrl         String?   @map("file_url") @db.VarChar(500)
  fileDurationSec Int?      @map("file_duration_sec")
  /// 0.0000 ~ 1.0000 AI 合成概率
  resultScore     Float?    @map("result_score")
  /// 'low' | 'medium' | 'high'
  resultLabel     String?   @map("result_label") @db.VarChar(20)
  resultFeatures  Json?     @map("result_features")
  aiProvider      String?   @map("ai_provider") @db.VarChar(50)
  aiRawResponse   Json?     @map("ai_raw_response")
  /// 'queued' | 'processing' | 'done' | 'failed'
  status          String    @default("queued") @db.VarChar(20)
  /// 用户反馈：'accurate' | 'inaccurate' | null
  userFeedback    String?   @map("user_feedback") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  /// created_at + 24h，cron 清理 R2 文件
  expiresAt       DateTime  @map("expires_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("deepfake_checks")
}

// --------------------------------------------
// V3-F 暗网监控（仅海外）
// --------------------------------------------
model BreachTarget {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 'email'（一期仅 email；二期 phone / cc）
  targetType            String    @default("email") @map("target_type") @db.VarChar(20)
  /// bcrypt(email)，用户能确认是自己的目标（展示用，脱敏字符串）
  targetValueHash       String    @map("target_value_hash")
  /// SHA256(lower(email)) + user salt — HIBP 查询用（不可逆）
  targetValueLookup     String    @map("target_value_lookup")
  /// AES-GCM 加密的真实邮箱（HIBP 调用时解密）；密钥 BREACH_AES_KEY 配置在 env
  /// 未配置密钥时为 null，HIBP 降级到 stub
  targetValueEncrypted  String?   @map("target_value_encrypted")
  verified              Boolean   @default(false)
  verificationToken     String?   @map("verification_token")
  verificationExpiresAt DateTime? @map("verification_expires_at")
  lastScannedAt         DateTime? @map("last_scanned_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  alerts BreachAlert[]

  @@unique([userId, targetValueLookup])
  @@index([userId])
  @@index([verified, lastScannedAt])
  @@map("breach_targets")
}

model BreachAlert {
  id           String       @id @default(cuid())
  targetId     String       @map("target_id")
  target       BreachTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  breachSource String       @map("breach_source") @db.VarChar(50) // 'HIBP' | 'DeHashed'
  breachName   String       @map("breach_name") @db.VarChar(200)
  breachDate   DateTime?    @map("breach_date") @db.Date
  exposedData  Json         @map("exposed_data") // ['email','password','phone']
  severity     String       @db.VarChar(20) // 'low' | 'medium' | 'high'
  dismissed    Boolean      @default(false)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("breach_alerts")
}

// --------------------------------------------
// V3-E 官方匿名广播
// triggeredByUserId 仅服务端可见，DTO 必须 @Exclude 不返回给前端
// 排重：同家庭同 contentHash 当日仅 1 条
//   DB 层 partial unique 索引 family_broadcasts_group_hash_day_unique
//   见 migrations/20260529000100_v3_007_family_broadcast_unique（Prisma schema
//   无法表达表达式索引，必须靠 SQL migration 维护）。
// --------------------------------------------
model FamilyBroadcast {
  id                String      @id @default(cuid())
  groupId           String      @map("group_id")
  group             FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// ⚠️ 隐私：仅服务端可见，前端 DTO 必须排除
  /// S3-4：用户删号后置空（CASCADE 会丢失历史；SET NULL 保历史但去匿名化）
  triggeredByUserId String?     @map("triggered_by_user_id")
  triggeredBy       User?       @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  /// phone | url | sms | voice
  contentType       String      @map("content_type")
  /// sha256(normalized_content)，用于当日排重
  contentHash       String      @map("content_hash")
  /// 展示给家人的内容（可脱敏后的版本）
  contentDisplay    String      @map("content_display") @db.Text
  /// scam | safe | unknown
  resultLabel       String      @map("result_label")
  /// AI 检测特征 + 建议（JSON）
  resultDetail      Json        @map("result_detail")
  /// auto_query（自动）| manual_share（用户主动分享）
  source            String
  createdAt         DateTime    @default(now()) @map("created_at")

  @@index([groupId, createdAt(sort: Desc)])
  @@index([groupId, contentHash])
  @@map("family_broadcasts")
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

// --------------------------------------------
// V3-S1-5 推送设备登记
// 一个 deviceToken 全局唯一（同一台设备换用户登录时会迁移归属）；
// 同一个 user 可有多个设备（手机 + iPad）。
// platform = 'ios' | 'android'（一期仅 ios，但预留）
// environment = 'production' | 'sandbox'（决定走 api.push.apple.com 还是 sandbox）
// --------------------------------------------
model UserDevice {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceToken       String   @unique @map("device_token") @db.VarChar(255)
  platform          String   @db.VarChar(16)
  environment       String   @default("production") @map("environment") @db.VarChar(16)
  appVersion        String?  @map("app_version") @db.VarChar(32)
  locale            String?  @db.VarChar(16)
  /// 推送失败累计计数；超阈值视作 token 失效，清理时使用
  failureCount      Int      @default(0) @map("failure_count")
  /// 上次推送失败 reason（APNs response 的 reason 字段或本地错误码）
  lastFailureReason String?  @map("last_failure_reason") @db.VarChar(64)
  lastSeenAt        DateTime @default(now()) @map("last_seen_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([failureCount])
  @@map("user_devices")
}

model AuthIdentity {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String
  providerSub   String   @map("provider_sub")
  providerEmail String?  @map("provider_email")
  providerPhone String?  @map("provider_phone")
  isVerified    Boolean  @default(true) @map("is_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerSub])
  @@index([userId])
  @@index([providerEmail])
  @@index([providerPhone])
  @@map("auth_identities")
}

// --------------------------------------------
// 2) queries（user_id 可空，未登录也能问）
// --------------------------------------------
model Query {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id")
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversationId String?   @map("conversation_id") // 同一对话内多条消息共用一个 id，历史按会话聚合为一条
  inputType      String    @map("input_type") // text | phone | url | company | screenshot
  content        String    @db.Text
  imageUrl       String?   @map("image_url") // 用户上传的截图/图片 CDN 地址，供后台展示
  resultJson     Json?     @map("result_json")
  riskLevel      String?   @map("risk_level")
  confidence     Int?
  aiProvider     String?   @map("ai_provider")
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at") // 软删除：不为空则不展示给用户

  reports Report[] @relation("ReportRelatedQuery")

  @@index([userId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("queries")
}

// --------------------------------------------
// 3) risk_data
// --------------------------------------------
model RiskData {
  id           String   @id @default(cuid())
  type         String // phone | url | company | wallet | keyword
  content      String   @db.Text
  riskLevel    String   @map("risk_level") // high | medium | low
  riskCategory String?  @map("risk_category")
  tags         Json     @default("[]") // JSON 数组
  source       String?
  evidence     String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([riskLevel])
  @@map("risk_data")
}

// --------------------------------------------
// 4) knowledge_cases（RAG 关键词检索用）
// --------------------------------------------
model KnowledgeCase {
  id               String           @id @default(cuid())
  title            String
  category         String
  // content 为纯文本（用于 RAG 关键词搜索 + 旧客户端兼容）；若 contentBlocks 存在则由其自动派生纯文本写入此字段
  content          String           @db.Text
  // 文章结构化内容：TipTap JSON（type/content/attrs），iOS 端按 block 类型原生渲染
  // null 表示旧的纯文本案例；客户端遇 null 时降级展示 content 字段
  contentBlocks    Json?            @map("content_blocks")
  // 封面图（可选）：列表页缩略图与详情页顶图，R2 URL
  coverImage       String?          @map("cover_image")
  tags             Json             @default("[]") // JSON 数组
  language         String           @default("zh")
  source           String?
  // V3-K：'published'（对外可见）| 'draft'（仅 admin 可见，AI 抓取入库默认 draft）| 'archived'
  // 历史数据全部默认 'published' 不影响展示
  status           String           @default("published") @db.VarChar(20)
  /// V3-K AI 抓取来源：哪个 ContentFetchJob 抓出来的
  sourceFetchJobId String?          @map("source_fetch_job_id") @db.VarChar(64)
  sourceFetchJob   ContentFetchJob? @relation(fields: [sourceFetchJobId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([language])
  @@index([status, language])
  @@index([sourceFetchJobId])
  @@map("knowledge_cases")
}

// --------------------------------------------
// 4.5) knowledge category config（知识库分类配置，Admin 管理，客户端按语言展示）
// --------------------------------------------
model KnowledgeCategoryConfig {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(64) // 业务 key，用于与 KnowledgeCase.category 对应
  nameZh    String   @map("name_zh") @db.VarChar(100)
  nameEn    String   @map("name_en") @db.VarChar(100)
  status    String   @default("active") @db.VarChar(20) // active | offline
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, sortOrder])
  @@map("knowledge_category_config")
}

// --------------------------------------------
// 5) reports
// --------------------------------------------
model Report {
  id             String       @id @default(cuid())
  userId         String?      @map("user_id")
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String // text | phone | url | screenshot
  content        String       @db.Text
  status         ReportStatus @default(PENDING)
  relatedQueryId String?      @map("related_query_id")
  relatedQuery   Query?       @relation("ReportRelatedQuery", fields: [relatedQueryId], references: [id], onDelete: SetNull)
  handledBy      String?      @map("handled_by")
  handledAt      DateTime?    @map("handled_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("reports")
}

enum ReportStatus {
  PENDING
  HANDLED
  REJECTED
}

// --------------------------------------------
// 6) subscriptions
// --------------------------------------------
model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId             String    @map("product_id")
  planType              String    @default("monthly") @map("plan_type") // weekly | monthly | yearly
  status                String // active | expired | cancelled | refunded | revoked
  expireTime            DateTime  @map("expire_time")
  transactionId         String?   @map("transaction_id")
  originalTransactionId String?   @map("original_transaction_id")
  latestTransactionId   String?   @map("latest_transaction_id")
  environment           String?   @db.VarChar(20)
  autoRenewStatus       Boolean?  @map("auto_renew_status")
  purchaseTime          DateTime? @map("purchase_time")
  refundedAt            DateTime? @map("refunded_at")
  revokedAt             DateTime? @map("revoked_at")
  lastEventType         String?   @map("last_event_type") @db.VarChar(80)
  historyLog            Json?     @map("history_log")
  paymentMethod         String    @map("payment_method") // Apple | Google
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // 防并发竞态：同一 Apple transactionId 不能产生重复记录
  // 历史脏数据需先用 dedupe 迁移清理（见 add_subscription_unique_indexes 迁移）
  @@unique([transactionId], map: "subscriptions_transaction_id_uq")
  @@index([userId])
  @@index([status, expireTime])
  @@index([originalTransactionId])
  @@index([latestTransactionId])
  @@map("subscriptions")
}

// --------------------------------------------
// 会员套餐配置表（Admin 管理，iOS 通过 GET /api/membership/plans 拉取）
// --------------------------------------------
model MembershipPlan {
  id                String   @id @default(cuid())
  name              String   @db.VarChar(100)
  productId         String   @map("product_id") @db.VarChar(64)
  price             Float
  currency          String   @db.VarChar(10)
  period            String   @db.VarChar(20) // weekly | monthly | yearly
  /// V3 新增：套餐档位
  /// 'personal'：单用户配额
  /// 'family'：家庭 owner 付费 → 同家庭全员共享配额（详见 query 配额体系）
  tier              String   @default("personal") @db.VarChar(20)
  description       String?  @db.Text
  introPrice        Float?   @map("intro_price")
  introPeriod       String?  @map("intro_period") @db.VarChar(20)
  firstPurchaseOnly Boolean  @default(false) @map("first_purchase_only")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  isRecommended     Boolean  @default(false) @map("is_recommended")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([isActive])
  @@index([tier, isActive])
  @@map("membership_plans")
}

// --------------------------------------------
// 7) ai_logs（调用日志）
// --------------------------------------------
model AiLog {
  id         String   @id @default(cuid())
  provider   String
  model      String?
  tokens     Int?
  latencyMs  Int?     @map("latency_ms")
  promptHash String?  @map("prompt_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("ai_logs")
}

// --------------------------------------------
// 8) admin_audit_logs（操作审计）
// --------------------------------------------
model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String   @map("admin_id")
  /// 操作动作：user.disable / user.enable / family.broadcast.recall / intel.publish / ...
  action      String   @db.VarChar(80)
  /// 目标类型：user / family_broadcast / intel_alert / ...
  targetType  String?  @map("target_type") @db.VarChar(40)
  targetId    String?  @map("target_id")
  /// S3-7：操作前快照（部分字段）；用于审计回放
  beforeValue Json?    @map("before_value")
  /// 操作后快照（部分字段）
  afterValue  Json?    @map("after_value")
  /// 操作来源 IP（X-Forwarded-For 取第一个）
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  /// User-Agent 截断 256 字符
  userAgent   String?  @map("user_agent") @db.VarChar(256)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// --------------------------------------------
// 9) settings（MVP 可先读 env，预留后台修改）
// --------------------------------------------
model Settings {
  id               String   @id @default(cuid())
  defaultProvider  String   @map("default_provider") // doubao | deepseek | openai | other
  fallbackProvider String?  @map("fallback_provider") // 主 provider 失败时切换的备用 provider；null 表示不切换
  doubaoKey        String?  @map("doubao_key")
  deepseekKey      String?  @map("deepseek_key")
  openaiKey        String?  @map("openai_key")
  aiBaseUrl        String?  @map("ai_base_url")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// --------------------------------------------
// 10) app_messages（后台下发给客户端的消息：标题、内容、跳转链接、发布时间；status=offline 时客户端不展示）
// --------------------------------------------
model AppMessage {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(200)
  content   String   @db.Text
  link      String?  @db.VarChar(500)
  language  String   @default("zh") @db.VarChar(10) // zh | en
  status    String   @default("active") @db.VarChar(20) // active | offline
  createdAt DateTime @default(now()) @map("created_at")

  readBy UserMessageRead[]

  @@index([language])
  @@map("app_messages")
}

// --------------------------------------------
// 用户意见反馈（客户端提交文案+一张图，Admin 查看）
// --------------------------------------------
model UserFeedback {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  content   String   @db.Text
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("user_feedback")
}

// 用户已读记录（用于小红点）
model UserMessageRead {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String     @map("message_id")
  message   AppMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  readAt    DateTime   @default(now()) @map("read_at")

  @@unique([userId, messageId])
  @@index([userId])
  @@map("user_message_read")
}

// --------------------------------------------
// V3-K AI 内容抓取 job 表
// 每点击一次 admin "抓情报/案例" 按钮 = 一条 job
// 状态机：pending → running → done|failed
// 与 IntelAlert.sourceFetchJobId / KnowledgeCase.sourceFetchJobId 关联
// --------------------------------------------
model ContentFetchJob {
  id              String    @id @default(cuid())
  /// 'intel' | 'knowledge'
  type            String    @db.VarChar(20)
  /// 'pending' | 'running' | 'done' | 'failed'
  status          String    @default("pending") @db.VarChar(20)
  /// 触发者 admin userId
  triggeredBy     String    @map("triggered_by")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  /// 各源抓到的候选总数
  totalFound      Int       @default(0) @map("total_found")
  /// 实际入库新增条数（每个 RawItem 入库 zh+en 两条）
  totalInserted   Int       @default(0) @map("total_inserted")
  /// 被 30 天去重过滤的条数
  totalDuplicated Int       @default(0) @map("total_duplicated")
  /// 改写/翻译失败的条数
  totalFailed     Int       @default(0) @map("total_failed")
  errorMessage    String?   @map("error_message") @db.Text
  /// 结果摘要：[{source, title, sourceUrl, status: 'inserted'|'duplicated'|'failed'}]
  resultJson      Json?     @map("result_json")
  createdAt       DateTime  @default(now()) @map("created_at")

  alerts         IntelAlert[]
  knowledgeCases KnowledgeCase[]

  @@index([type, createdAt(sort: Desc)])
  @@index([triggeredBy, createdAt(sort: Desc)])
  @@map("content_fetch_jobs")
}
